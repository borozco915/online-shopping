<!DOCTYPE html>
<html>
<head>
    <title>Your Cart</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="bg-light">
   <%- include('partials/navbar') %>

<div class="container mt-5">

    <h1 class="mb-4">🛒 Your Cart</h1>

    <% if (cart.length === 0) { %>
        <div class="text-center">
            <h4>Your cart is empty</h4>
            <a href="/" class="btn btn-primary mt-3">Shop Now</a>
        </div>
    <% } else { %>

    <div class="row">

        <!-- 🛍️ CART ITEMS -->
        <div class="col-md-8">

            <% cart.forEach(item => { %>
                <div class="card mb-3 p-3 shadow-sm cart-item">

                    <div class="row align-items-center">

                        <!-- IMAGE -->
                        <div class="col-md-3">
                            <img src="<%= item.img || 'https://via.placeholder.com/150' %>" 
                                 class="img-fluid rounded">
                        </div>

                        <!-- DETAILS -->
                        <div class="col-md-5">
                            <h5><%= item.name %></h5>
                            <p class="text-muted">Premium Jersey</p>
                        </div>

                        <!-- PRICE -->
                        <div class="col-md-2 text-center">
                            <p class="fw-bold">$<%= item.price %></p>
                        </div>

                        <!-- REMOVE -->
                        <div class="col-md-2 text-end">
                            <form action="/cart/remove/<%= item.id %>" method="POST">
                                <button class="btn btn-outline-danger btn-sm">Remove</button>
                            </form>
                        </div>

                    </div>

                </div>
            <% }) %>

        </div>

        <!-- 💰 ORDER SUMMARY -->
        <div class="col-md-4">

            <div class="card p-4 shadow-sm">

                <h4>Order Summary</h4>

                <hr>

                <p>
                    Items: <strong><%= cart.length %></strong>
                </p>

                <p>
                    Total:
                    <strong>
                        $<%= cart.reduce((sum, item) => sum + item.price, 0) %>
                    </strong>
                </p>

                <a href="/checkout" class="btn btn-success w-100 mt-3">
                    Checkout
                </a>

            </div>

        </div>

    </div>

    <% } %>

    <a href="/" class="btn btn-secondary mt-4">← Continue Shopping</a>

</div>

</body>


</html>