<div class="product-modal" id="product-modal" hidden aria-hidden="true">
  <div class="product-modal__backdrop" data-close-modal></div>
  <div class="product-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="product-modal-title">
    <button class="product-modal__close" type="button" aria-label="Close quick view" data-close-modal>&times;</button>

    <div class="product-modal__content">
      <div class="product-visual">
        <div class="product-visual__stage">
          <div class="product-visual__ring" id="spin-stage">
            <img id="product-modal-image" src="" alt="" class="product-visual__image">
          </div>
        </div>

        <div class="product-visual__controls">
          <div class="product-visual__header">
            <span class="product-visual__label">360 View</span>
            <button type="button" class="btn btn-sm btn-outline-dark" id="spin-toggle">Auto Spin</button>
          </div>

          <input id="spin-range" class="form-range" type="range" min="0" max="360" step="1" value="0" aria-label="Rotate jersey preview">
          <p class="product-visual__hint mb-0">Drag the slider or use auto spin to inspect the shirt.</p>
        </div>
      </div>

      <div class="product-details">
        <p class="product-details__eyebrow mb-2">Quick View</p>
        <h3 id="product-modal-title" class="mb-2"></h3>
        <p id="product-modal-price" class="product-details__price"></p>
        <p id="product-modal-description" class="product-details__description"></p>

        <div class="product-details__sizes">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <h4 class="product-details__section-title mb-0">Available Sizes</h4>
            <span id="selected-size-label" class="product-details__selected">Select a size</span>
          </div>
          <div id="product-modal-sizes" class="size-options"></div>
        </div>

        <form id="product-modal-form" method="POST">
          <input type="hidden" id="product-modal-selected-size" name="size" value="">
          <button class="btn btn-primary w-100 product-details__cta" type="submit">Add to Cart</button>
        </form>
      </div>
    </div>
  </div>
</div>
