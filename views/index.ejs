<!DOCTYPE html>
<html>
<head>
    <title>Soccer Jersey Store</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/styles.css">
</head>
<script>
  setTimeout(() => {
    const alert = document.querySelector('.alert');
    if (alert) alert.style.display = 'none';
  }, 3000);
</script>
<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container mt-5">
    <% if (query && query.added) { %>
      <div class="alert alert-success text-center">
        Item added to cart!
      </div>
    <% } %>

    <div class="text-center mb-5">
        <h1 class="fw-bold">Soccer Jersey Marketplace</h1>
        <p class="text-muted">Clean microservice UI</p>
    </div>

    <div class="row">
        <% jerseys.forEach(j => { %>
            <div class="col-md-4">
                <div class="card jersey-card mb-4">
                    <button
                        type="button"
                        class="product-image-button"
                        data-product-trigger
                        data-id="<%= j.id %>"
                        data-name="<%= j.name %>"
                        data-price="<%= j.price %>"
                        data-img="<%= j.img || 'https://via.placeholder.com/300' %>"
                        data-description="<%= j.description %>"
                        data-sizes="<%= j.sizes.join(',') %>"
                        aria-label="Open details for <%= j.name %>">
                        <img src="<%= j.img || 'https://via.placeholder.com/300' %>" 
                             class="card-img-top jersey-image"
                             alt="<%= j.name %>">
                    </button>

                    <div class="card-body text-center">
                        <h5><%= j.name %></h5>
                        <p class="price">$<%= j.price %></p>
                    <div class="d-grid gap-2">
                        <a href="/product/<%= j.id %>" class="btn btn-outline-dark">View Details</a>
                        <form action="/cart/<%= j.id %>" method="POST">
                            <button class="btn btn-primary w-100">Add to Cart</button>
                        </form>
                    </div>
                    </div>

                </div>
            </div>
        <% }) %>
    </div>

</div>

<%- include('partials/product-modal') %>
<script src="/product-actions.js"></script>

</body>
</html>
