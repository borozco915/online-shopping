<!DOCTYPE html>
<html>
<head>
    <title>Soccer Jersey Store</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/styles.css">
</head>
<script>
  setTimeout(() => {
    const alert = document.querySelector('.alert');
    if (alert) alert.style.display = 'none';
  }, 3000);
</script>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
    <div class="container">
        <span class="navbar-brand">⚽ Jersey Store</span>
        <a href="/cart" class="btn btn-warning">
            🛒 Cart (<%= typeof cart !== 'undefined' ? cart.length : 0 %>)
        </a>
        <a href="/store" class="btn btn-primary">View Jerseys</a>
    </div>
</nav>

<div class="container mt-5">
    <!-- ✅ ADD THIS BLOCK RIGHT HERE -->
    <% if (query && query.added) { %>
      <div class="alert alert-success text-center">
        Item added to cart!
      </div>
    <% } %>

    <div class="text-center mb-5">
        <h1 class="fw-bold">Soccer Jersey Marketplace</h1>
        <p class="text-muted">Clean microservice UI</p>
    </div>

    <div class="row">
        <% jerseys.forEach(j => { %>
            <div class="col-md-4">
                <div class="card jersey-card mb-4">
                    
                    <img src="<%= j.img || 'https://via.placeholder.com/300' %>" 
                         class="card-img-top" 
                         style="height:250px; object-fit:cover;">

                    <div class="card-body text-center">
                        <h5><%= j.name %></h5>
                        <p class="price">$<%= j.price %></p>
                    <form action="/cart/<%= j.id %>" method="POST">
                        <button class="btn btn-primary">Add to Cart</button>
                    </form>
                    </div>

                </div>
            </div>
        <% }) %>
    </div>

</div>

</body>
</html>