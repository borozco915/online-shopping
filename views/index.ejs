<!DOCTYPE html>
<html>
<head>
    <title>Soccer Jersey Store</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
    <div class="container">
        <span class="navbar-brand">⚽ Jersey Store</span>
        <a href="/cart" class="btn btn-warning">🛒 Cart (<%= jerseys.length %>)</a>
        <a href="/store" class="btn btn-primary">View Jerseys</a>
    </div>
</nav>

<div class="container mt-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold">Soccer Jersey Marketplace</h1>
        <p class="text-muted">Clean microservice UI</p>
    </div>

    <div class="row">
        <% jerseys.forEach(j => { %>
            <div class="col-md-4">
                <div class="card jersey-card mb-4">
                    
                    <img src="<%= j.img || 'https://via.placeholder.com/200' %>" class="card-img-top">

                    <div class="card-body text-center">
                        <h5><%= j.name %></h5>
                        <p class="price">$<%= j.price %></p>
                    <form action="/cart/<%= j.id %>" method="POST">
                        <button class="btn btn-primary">Add to Cart</button>
                    </form>
                    </div>

                </div>
            </div>
        <% }) %>
    </div>

</div>

</body>
</html>