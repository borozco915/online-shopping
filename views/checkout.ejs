<!DOCTYPE html>
<html>
<head>
    <title>Checkout</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <link rel="stylesheet" href="/styles.css">
</head>
<script>
const cardNumber = document.querySelector('input[name="cardNumber"]');
const cardName = document.querySelector('input[name="name"]');
const cardExp = document.querySelector('input[name="exp"]');

cardNumber.addEventListener('input', () => {
    document.getElementById('card-number-preview').innerText =
        cardNumber.value || '•••• •••• •••• ••••';
});

cardName.addEventListener('input', () => {
    document.getElementById('card-name-preview').innerText =
        cardName.value || 'Your Name';
});

cardExp.addEventListener('input', () => {
    document.getElementById('card-exp-preview').innerText =
        cardExp.value || 'MM/YY';
});

document.querySelector("form").addEventListener("submit", (e) => {
    const number = cardNumber.value.replace(/\s/g, "");

    if (number.length < 16) {
        alert("Invalid card number");
        e.preventDefault();
    }
});
</script>

<body class="bg-light">

<div class="container mt-5">

    <h2 class="mb-4 fw-bold">Checkout</h2>

    <div class="row g-4">

        <!-- 🧍 CUSTOMER INFO -->
        <div class="col-md-7">

            <div class="card p-4 shadow-sm">
                <h5 class="mb-3"><i class="bi bi-person"></i> Customer Info</h5>

                <form action="/checkout" method="POST">

                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input name="name" class="form-control" placeholder="John Doe" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input name="email" type="email" class="form-control" placeholder="john@email.com" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Shipping Address</label>
                        <input name="address" class="form-control" placeholder="123 Main St" required>
                    </div>
                    <h5 class="mt-4 mb-3">
    <i class="bi bi-credit-card"></i> Payment Details
</h5>

<div class="card p-3 bg-dark text-white mb-3" id="card-preview">
    <div class="mb-2">💳 Credit Card</div>
    <h5 id="card-number-preview">•••• •••• •••• ••••</h5>
    <div class="d-flex justify-content-between">
        <small id="card-name-preview">Your Name</small>
        <small id="card-exp-preview">MM/YY</small>
    </div>
</div>

<div class="mb-3">
    <label>Card Number</label>
    <input name="cardNumber" class="form-control" maxlength="19" placeholder="1234 5678 9012 3456" required>
</div>

<div class="row">
    <div class="col-md-6">
        <label>Expiration</label>
        <input name="exp" class="form-control" placeholder="MM/YY" required>
    </div>

    <div class="col-md-6">
        <label>CVV</label>
        <input name="cvv" class="form-control" maxlength="4" placeholder="123" required>
    </div>
</div>
                    <button class="btn btn-success w-100 mt-3">
                        <i class="bi bi-bag-check"></i> Place Order
                    </button>

                </form>
            </div>

        </div>

        <!-- 💰 ORDER SUMMARY -->
        <div class="col-md-5">

            <div class="card p-4 shadow-sm">

                <h5 class="mb-3"><i class="bi bi-receipt"></i> Order Summary</h5>

                <% cart.forEach(item => { %>
                    <div class="d-flex justify-content-between mb-2">
                        <span><%= item.name %> (<%= item.size || 'Standard' %>) x <%= item.qty || 1 %></span>
                        <span>$<%= item.price * (item.qty || 1) %></span>
                    </div>
                <% }) %>

                <hr>

                <div class="d-flex justify-content-between fw-bold">
                    <span>Total</span>
                    <span>
                        $<%= cart.reduce((sum, item) => sum + (item.price * (item.qty || 1)), 0) %>
                    </span>
                </div>

            </div>

        </div>

    </div>

</div>

</body>
</html>
