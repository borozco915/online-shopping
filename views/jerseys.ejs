<!DOCTYPE html>
<html>
<head>
    <title>All Jerseys</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container mt-5">

    <h2 class="text-center mb-4">Available Jerseys</h2>
    <% if (search) { %>
        <p class="text-center text-muted mb-4">Showing results for "<%= search %>"</p>
    <% } %>

    <% if (jerseys.length === 0) { %>
        <div class="card shadow-sm p-4 text-center empty-state-card">
            <h4 class="mb-2">No jerseys matched your search.</h4>
            <p class="text-muted mb-0">Try another club, city, or team name from the navbar search.</p>
        </div>
    <% } %>

    <div class="row">
        <% jerseys.forEach(j => { %>
            <div class="col-md-4">
                <div class="card jersey-card mb-4">
                    <button
                        type="button"
                        class="product-image-button"
                        data-product-trigger
                        data-id="<%= j.id %>"
                        data-name="<%= j.name %>"
                        data-price="<%= j.price %>"
                        data-img="<%= j.img || 'https://via.placeholder.com/200' %>"
                        data-description="<%= j.description %>"
                        data-sizes="<%= j.sizes.join(',') %>"
                        aria-label="Open details for <%= j.name %>">
                        <img src="<%= j.img || 'https://via.placeholder.com/200' %>" class="card-img-top jersey-image" alt="<%= j.name %>">
                    </button>

                    <div class="card-body text-center">
                        <h5><%= j.name %></h5>
                        <p class="price">$<%= j.price %></p>

                        <form action="/cart/<%= j.id %>" method="POST">
                            <button class="btn btn-success">Add to Cart</button>
                        </form>

                        <div class="product-secondary-actions">
                            <form action="/wishlist/<%= j.id %>" method="POST">
                                <button class="btn btn-outline-danger btn-sm w-100">Add to Wishlist</button>
                            </form>
                            <form action="/saved/<%= j.id %>" method="POST">
                                <button class="btn btn-outline-secondary btn-sm w-100">Save for Later</button>
                            </form>
                        </div>
                    </div>

                </div>
            </div>
        <% }) %>
    </div>

</div>

<%- include('partials/product-modal') %>
<script src="/product-actions.js"></script>

</body>
</html>
